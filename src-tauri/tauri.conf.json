{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "绘心启动器",
  "version": "0.1.0",
  "identifier": "com.xnnehanglab.launchertemplate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "绘心启动器",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 760,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
